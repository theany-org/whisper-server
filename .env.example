# PostgreSQL
POSTGRES_USER=whisper
POSTGRES_PASSWORD=changeme
POSTGRES_DB=whisper
DATABASE_URL=postgresql+asyncpg://whisper:changeme@localhost:5432/whisper

# Redis
REDIS_PASSWORD=changeme
REDIS_URL=redis://:changeme@localhost:6379/0

# JWT — CHANGE THIS in production (use: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=CHANGE-ME-generate-a-64-char-hex-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# Rate limiting
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=300

# CORS — comma-separated allowed origins (leave empty to block all cross-origin requests)
CORS_ORIGINS=

# Environment — "development" enables /docs, "production" disables it
ENVIRONMENT=production

# WebSocket auth ticket lifetime in seconds
WS_TICKET_TTL=30

# Trusted reverse proxy IPs/CIDRs allowed to set X-Forwarded-For
# Comma-separated, e.g. "127.0.0.1,10.0.0.0/8"
TRUSTED_PROXIES=

# ─── coturn (self-hosted STUN/TURN) ───────────────────────────────────────────
# Your server's public IPv4 — run: curl -s ifconfig.me
COTURN_EXTERNAL_IP=1.2.3.4

# Domain or IP clients connect to (can be same as your API domain, or raw IP)
COTURN_REALM=turn.yourdomain.com

# Strong random secret for signing TURN credentials
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
COTURN_SECRET=CHANGE-ME-generate-a-64-char-hex-secret
